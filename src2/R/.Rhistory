# 3. NN feature preprocessing (min-max scaling, embedding indices)
###############################################################################
PreProcess.Continuous <- function(var1, data2) {
names(data2)[names(data2) == var1] <- "V1"
data2$X <- as.numeric(data2$V1)
data2$X <- 2 * (data2$X - min(data2$X)) / (max(data2$X) - min(data2$X)) - 1
names(data2)[names(data2) == "V1"] <- var1
names(data2)[names(data2) == "X"]  <- paste0(var1, "X")
data2
}
data <- PreProcess.Continuous("Area", data)
data <- PreProcess.Continuous("VehPower", data)
data$VehAge <- pmin(data$VehAge, 20)
data <- PreProcess.Continuous("VehAge", data)
data$DrivAge <- pmin(data$DrivAge, 90)
data <- PreProcess.Continuous("DrivAge", data)
data$BonusMalus <- pmin(data$BonusMalus, 150)
data <- PreProcess.Continuous("BonusMalus", data)
data$VehBrandX <- as.integer(data$VehBrand) - 1
data$VehGasX   <- as.integer(data$VehGas) - 1.5
data$Density   <- round(log(data$Density), 2)
data <- PreProcess.Continuous("Density", data)
data$RegionX   <- as.integer(data$Region) - 1
###############################################################################
# 4. Train/test split (90/10)
###############################################################################
set.seed(100)
ll    <- sample(1:nrow(data), round(0.9 * nrow(data)), replace = FALSE)
learn <- data[ll, ]
test  <- data[-ll, ]
cat("Learn:", nrow(learn), "rows | Test:", nrow(test), "rows\n\n")
# GLM design matrices
glm_features <- c("VehPowerGLM", "VehAgeGLM", "DrivAgeGLM", "BonusMalusGLM",
"VehBrandGLM", "VehGasGLM", "DensityGLM", "RegionGLM", "AreaGLM")
X_learn <- as.matrix(learn[glm_features])
X_test  <- as.matrix(test[glm_features])
y_learn <- learn$ClaimNb
y_test  <- test$ClaimNb
E_learn <- learn$Exposure
E_test  <- test$Exposure
n_learn <- nrow(learn)
n_test  <- nrow(test)
p       <- ncol(X_learn)
###############################################################################
# Helper functions: Stirling2, Bell numbers, Bell PMF
###############################################################################
Stirling2 <- function(n, m) {
if (0 > m || m > n) stop("'m' must be in 0..n !")
k   <- 0:m
sig <- rep(c(1, -1) * (-1)^m, length = m + 1)
ga  <- gamma(k + 1)
round(sum(sig * k^n / (ga * rev(ga))))
}
fBell <- function(x) {
if (x == 0) return(1)
sum(sapply(1:x, function(j) Stirling2(x, j)))
}
# Precompute Bell numbers for y = 0..4
BELL_NUMBERS <- sapply(0:4, fBell)
Bell_pmf <- function(mu, y) {
mu <- max(mu, 1e-10)
w <- Re(W(mu))  # take real part to avoid complex NaN
val <- exp(1 - exp(w)) * (w^y) * BELL_NUMBERS[y + 1] / factorial(y)
if (is.nan(val) || is.na(val)) return(1e-300)
return(max(val, 1e-300))
}
###############################################################################
# Deviance functions
###############################################################################
Bell.Deviance <- function(obs, pred) {
loss <- numeric(length(obs))
for (i in seq_along(obs)) {
wp <- Re(W(max(pred[i], 1e-10)))
if (obs[i] == 0) {
loss[i] <- 2 * (-1 + exp(wp))
} else {
wo <- Re(W(max(obs[i], 1e-10)))
loss[i] <- 2 * (exp(wp) - exp(wo) + log((wo / wp)^obs[i]))
}
}
mean(loss)
}
Poisson.Deviance <- function(obs, pred) {
2 * (sum(pred) - sum(obs) + sum(log((obs / pred)^obs))) / length(pred)
}
NegBin.Deviance <- function(obs, pred, alpha) {
loss <- numeric(length(obs))
for (i in seq_along(obs)) {
y <- obs[i]
mu <- pred[i]
if (y == 0) {
loss[i] <- 2 * (1 / alpha) * log(1 / (1 + alpha * mu))
loss[i] <- -loss[i]  # make positive: 2*(1/a)*log(1+a*mu)
} else {
loss[i] <- 2 * (y * log(y / mu) - (y + 1 / alpha) * log((1 + alpha * y) / (1 + alpha * mu)))
}
}
mean(loss)
}
###############################################################################
# 5a. Poisson GLM
###############################################################################
cat("--- Fitting Poisson GLM ---\n")
POI_nll <- function(pars) {
lambda <- exp(log(E_learn) + X_learn %*% pars)
-sum(dpois(y_learn, lambda, log = TRUE))
}
opt_poi <- optim(par = rep(0, p), fn = POI_nll, method = "BFGS")
cat("Poisson GLM converged:", opt_poi$convergence == 0, "\n")
cat("Poisson NLL:", opt_poi$value, "\n")
learn$poissonGLM <- as.numeric(exp(log(E_learn) + X_learn %*% opt_poi$par))
test$poissonGLM  <- as.numeric(exp(log(E_test)  + X_test  %*% opt_poi$par))
cat("Poisson Deviance — Train:", Poisson.Deviance(y_learn, learn$poissonGLM),
"| Test:", Poisson.Deviance(y_test, test$poissonGLM), "\n\n")
###############################################################################
# 5b. Bell GLM
###############################################################################
cat("--- Fitting Bell GLM ---\n")
Bell_nll <- function(pars) {
mu <- pmax(exp(log(E_learn) + X_learn %*% pars), 1e-10)
w  <- Re(W(mu))  # vectorized Lambert W
# Vectorized log-PMF: log(exp(1-exp(w)) * w^y * B_y / y!)
log_pmf <- (1 - exp(w)) + y_learn * log(pmax(w, 1e-30)) +
log(BELL_NUMBERS[y_learn + 1]) - lfactorial(y_learn)
-sum(log_pmf)
}
opt_bell <- optim(par = c(rep(0.001, 5), -1, rep(-0.001, 3)),
fn = Bell_nll, method = "BFGS")
cat("Bell GLM converged:", opt_bell$convergence == 0, "\n")
cat("Bell NLL:", opt_bell$value, "\n")
learn$bellGLM <- as.numeric(exp(log(E_learn) + X_learn %*% opt_bell$par))
test$bellGLM  <- as.numeric(exp(log(E_test)  + X_test  %*% opt_bell$par))
cat("Bell Deviance — Train:", Bell.Deviance(y_learn, learn$bellGLM),
"| Test:", Bell.Deviance(y_test, test$bellGLM), "\n\n")
###############################################################################
# 5c. NegBin GLM
###############################################################################
cat("--- Fitting NegBin GLM ---\n")
# Build a proper data frame for glm.nb
learn_glm_df <- data.frame(
ClaimNb  = y_learn,
Exposure = E_learn,
X_learn
)
test_glm_df <- data.frame(
ClaimNb  = y_test,
Exposure = E_test,
X_test
)
nb_formula <- as.formula(paste(
"ClaimNb ~", paste(glm_features, collapse = " + "), "+ offset(log(Exposure))"
))
nb_fit <- glm.nb(nb_formula, data = learn_glm_df)
cat("NegBin theta (1/alpha):", nb_fit$theta, "\n")
negbin_alpha <- 1 / nb_fit$theta
learn$negbinGLM <- predict(nb_fit, newdata = learn_glm_df, type = "response")
test$negbinGLM  <- predict(nb_fit, newdata = test_glm_df,  type = "response")
cat("NegBin Deviance — Train:", NegBin.Deviance(y_learn, learn$negbinGLM, negbin_alpha),
"| Test:", NegBin.Deviance(y_test, test$negbinGLM, negbin_alpha), "\n\n")
###############################################################################
# 5d. ZIP GLM
###############################################################################
cat("--- Fitting ZIP GLM ---\n")
zip_formula <- as.formula(paste(
"ClaimNb ~", paste(glm_features, collapse = " + "),
"+ offset(log(Exposure)) |", paste(glm_features, collapse = " + ")
))
zip_fit <- zeroinfl(zip_formula, data = learn_glm_df, dist = "poisson")
learn$zipGLM <- predict(zip_fit, newdata = learn_glm_df, type = "response")
test$zipGLM  <- predict(zip_fit, newdata = test_glm_df,  type = "response")
# Extract zero-inflation probabilities
learn$pi_zip <- predict(zip_fit, newdata = learn_glm_df, type = "zero")
test$pi_zip  <- predict(zip_fit, newdata = test_glm_df,  type = "zero")
# Also extract the count component mean (mu before zero-inflation)
learn$mu_zip <- predict(zip_fit, newdata = learn_glm_df, type = "count")
test$mu_zip  <- predict(zip_fit, newdata = test_glm_df,  type = "count")
cat("ZIP Log-lik:", logLik(zip_fit), "\n")
cat("ZIP mean pred — Train:", mean(learn$zipGLM), "| Test:", mean(test$zipGLM), "\n\n")
###############################################################################
# 5e. ZINB GLM
###############################################################################
cat("--- Fitting ZINB GLM ---\n")
zinb_formula <- as.formula(paste(
"ClaimNb ~", paste(glm_features, collapse = " + "),
"+ offset(log(Exposure)) |", paste(glm_features, collapse = " + ")
))
zinb_fit <- zeroinfl(zinb_formula, data = learn_glm_df, dist = "negbin")
learn$zinbGLM <- predict(zinb_fit, newdata = learn_glm_df, type = "response")
test$zinbGLM  <- predict(zinb_fit, newdata = test_glm_df,  type = "response")
learn$pi_zinb <- predict(zinb_fit, newdata = learn_glm_df, type = "zero")
test$pi_zinb  <- predict(zinb_fit, newdata = test_glm_df,  type = "zero")
learn$mu_zinb <- predict(zinb_fit, newdata = learn_glm_df, type = "count")
test$mu_zinb  <- predict(zinb_fit, newdata = test_glm_df,  type = "count")
zinb_alpha <- 1 / zinb_fit$theta
cat("ZINB theta:", zinb_fit$theta, "(alpha =", zinb_alpha, ")\n")
cat("ZINB Log-lik:", logLik(zinb_fit), "\n")
cat("ZINB mean pred — Train:", mean(learn$zinbGLM), "| Test:", mean(test$zinbGLM), "\n\n")
###############################################################################
# 5f. ZI-Bell GLM (custom MLE)
###############################################################################
cat("--- Fitting ZI-Bell GLM ---\n")
# Parameters: first p for mu (count), next p for pi (zero-inflation), plus 2 intercepts
# mu_i = exp(log(E_i) + X_i %*% beta_mu)
# pi_i = 1 / (1 + exp(-(alpha_0 + X_i %*% beta_pi)))
ZIBell_nll <- function(pars) {
beta_mu <- pars[1:p]
alpha_0 <- pars[p + 1]
beta_pi <- pars[(p + 2):(2 * p + 1)]
mu <- pmax(exp(log(E_learn) + X_learn %*% beta_mu), 1e-10)
pi_val <- as.numeric(1 / (1 + exp(-(alpha_0 + X_learn %*% beta_pi))))
w <- Re(W(mu))  # vectorized
# Bell log-PMF for all observations (vectorized)
log_bell <- (1 - exp(w)) + y_learn * log(pmax(w, 1e-30)) +
log(BELL_NUMBERS[y_learn + 1]) - lfactorial(y_learn)
bell_pmf <- exp(log_bell)
is_zero <- (y_learn == 0)
ll <- numeric(n_learn)
# y == 0: log(pi + (1-pi)*Bell(0|mu))
ll[is_zero]  <- log(pmax(pi_val[is_zero] + (1 - pi_val[is_zero]) * bell_pmf[is_zero], 1e-300))
# y > 0:  log((1-pi)*Bell(y|mu))
ll[!is_zero] <- log(pmax(1 - pi_val[!is_zero], 1e-300)) + log_bell[!is_zero]
-sum(ll)
}
# Initial values: mu params from Bell GLM, pi params = 0 (50% zero-inflation)
init_zibell <- c(opt_bell$par, 0, rep(0, p))
opt_zibell <- tryCatch({
optim(par = init_zibell, fn = ZIBell_nll, method = "BFGS",
control = list(maxit = 5000))
}, error = function(e) {
cat("BFGS failed, trying Nelder-Mead...\n")
optim(par = init_zibell, fn = ZIBell_nll, method = "Nelder-Mead",
control = list(maxit = 10000))
})
cat("ZI-Bell GLM converged:", opt_zibell$convergence == 0, "\n")
cat("ZI-Bell NLL:", opt_zibell$value, "\n")
# Extract predictions for full data
zibell_predict <- function(X_mat, E_vec, pars) {
beta_mu <- pars[1:p]
alpha_0 <- pars[p + 1]
beta_pi <- pars[(p + 2):(2 * p + 1)]
mu <- as.numeric(exp(log(E_vec) + X_mat %*% beta_mu))
pi_raw <- as.numeric(alpha_0 + X_mat %*% beta_pi)
pi <- 1 / (1 + exp(-pi_raw))
# E[Y] = (1 - pi) * mu for ZI model
list(expected = (1 - pi) * mu, mu = mu, pi = pi)
}
zibell_learn <- zibell_predict(X_learn, E_learn, opt_zibell$par)
zibell_test  <- zibell_predict(X_test,  E_test,  opt_zibell$par)
learn$zibellGLM  <- zibell_learn$expected
test$zibellGLM   <- zibell_test$expected
learn$pi_zibell  <- zibell_learn$pi
test$pi_zibell   <- zibell_test$pi
learn$mu_zibell  <- zibell_learn$mu
test$mu_zibell   <- zibell_test$mu
cat("ZI-Bell mean pi — Train:", mean(learn$pi_zibell), "\n")
cat("ZI-Bell mean pred — Train:", mean(learn$zibellGLM), "| Test:", mean(test$zibellGLM), "\n\n")
###############################################################################
# 6. Export metadata
###############################################################################
# Save NegBin alpha for Python
alpha_df <- data.frame(
negbin_alpha = negbin_alpha,
zinb_alpha   = zinb_alpha
)
write.csv(alpha_df, file = "glm_metadata.csv", row.names = FALSE)
###############################################################################
# 7. Export learn/test CSVs
###############################################################################
write.csv(learn, file = "bell_learn.csv", row.names = FALSE)
write.csv(test,  file = "bell_test.csv",  row.names = FALSE)
cat("=== Exported bell_learn.csv (", nrow(learn), "rows) ===\n")
cat("=== Exported bell_test.csv  (", nrow(test),  "rows) ===\n")
cat("=== Exported glm_metadata.csv ===\n")
###############################################################################
# 8. Summary table
###############################################################################
cat("\n========== GLM RESULTS SUMMARY ==========\n")
cat(sprintf("%-15s  %12s  %12s\n", "Model", "Train NLL", "Parameters"))
cat(sprintf("%-15s  %12.1f  %12d\n", "Poisson GLM", opt_poi$value, p))
cat(sprintf("%-15s  %12.1f  %12d\n", "Bell GLM", opt_bell$value, p))
cat(sprintf("%-15s  %12.1f  %12d\n", "NegBin GLM", -as.numeric(logLik(nb_fit)), p + 1))
cat(sprintf("%-15s  %12.1f  %12d\n", "ZIP GLM", -as.numeric(logLik(zip_fit)), length(coef(zip_fit))))
cat(sprintf("%-15s  %12.1f  %12d\n", "ZINB GLM", -as.numeric(logLik(zinb_fit)), length(coef(zinb_fit)) + 1))
cat(sprintf("%-15s  %12.1f  %12d\n", "ZI-Bell GLM", opt_zibell$value, 2 * p + 1))
cat("==========================================\n")
